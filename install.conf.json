[
    {
        "clean": [
            "~"
        ]
    },
    {
        "shell": [
            ["mkdir -p ~/bin/ ~/.ssh/ ~/.config/sbackup/ ", "Creating dirs."]
        ]
    },
    {
        "link": {
            "~/.zshrc":"zshrc",
            "~/.gitconfig":"gitconfig",
            "~/.gitconfigQuirks":"gitconfigQuirks/",
            "~/.vimrc": "vimrc",
	          "~/.vim": "vim/",
	          "~/.config/bat": "config/bat/",
            "~/.bat/extras": "bat-extras/",
            "~/Library/Developer/Xcode/UserData/FontAndColorThemes": "xcode/",
            "~/Library/Application\\ Support/Sublime\\ Text/Packages/User": "sublime_text/Packages/User",
            "~/Library/Application\\ Support/Sublime\\ Text/Installed\\ Packages": "sublime_text/installed_packages",
            "~/.dotfiles": ""
        }
    },
    {
        "shell": [
            ["git submodule update --init --recursive", "Installing/updating submodules"]
        ]
    }
]
